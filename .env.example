# ------ Model Providers ------
# Active routing: Anthropic (researcher + synthesizer) + Google Gemini (cheap
# judge), called DIRECTLY via Mastra's model router — no OpenRouter gateway.
# Mastra reads these env vars by name (apiKeyEnvVar in its provider registry).

# Required. Anthropic key for the researcher + synthesizer. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Required. Google AI Studio key for the judge (scorers). https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional — only needed if you add an openrouter/*, openai/*, ollama-cloud/*,
# or github-models/* entry to a MODEL_*_POOL below.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_KEY=
GITHUB_TOKEN=

# ------ Model pools ------
# Comma-separated; the router round-robins entries per role. A single entry
# acts as a hard override ("always use exactly this model"). Format is
# "provider/model" — verify names against the installed Mastra version with:
#   node .agents/skills/mastra/scripts/provider-registry.mjs --provider anthropic
#   node .agents/skills/mastra/scripts/provider-registry.mjs --provider google
MODEL_RESEARCHER_POOL=anthropic/claude-haiku-4-5
MODEL_SYNTHESIZER_POOL=anthropic/claude-sonnet-4-6
MODEL_CHEAP_POOL=google/gemini-2.5-flash-lite

# ------ Tools API ------
# Web search provider. Default is Exa.
SEARCH_PROVIDER=exa

# Required when SEARCH_PROVIDER=exa. https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Optional. Alternative search provider (set SEARCH_PROVIDER=tavily to use).
# https://app.tavily.com
TAVILY_API_KEY=

# Required. JS-page fetch. https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# ------ Runtime settings ------
# DEFAULT_COMPANY_KEY=onix
